{
  "id": "nc.pockettts",
  "name": "PocketTTS",
  "version": "0.1.0",
  "entry_point": "main.py",
  "description": "Built-in PocketTTS backend exposed as an addon.",
  "category": "global",
  "permissions": [
    "services.register",
    "ui.tabs"
  ],
  "runtime_defaults": {
    "pocket_tts_builtin_voice": "auto",
    "pocket_tts_use_cloned_voice": true,
    "pocket_tts_prewarm_on_start": true
  },
  "services": [
    {
      "id": "tts_backend_service",
      "backend_id": "pockettts",
      "metadata": {
        "real_ui_bridge_module": "addons.pockettts.real_ui_bridge"
      }
    }
  ],
  "ui": [
    {
      "id": "pockettts_tab",
      "title": "PocketTTS",
      "area": "tts_runtime",
      "ui_path": "ui/pockettts.ui",
      "placeholder": "tts_pockettts_tab",
      "order": 200,
      "tooltip": "PocketTTS interpreter settings.",
      "metadata": {
        "backend_id": "pockettts",
        "real_ui_bridge_module": "addons.pockettts.real_ui_bridge"
      }
    }
  ],
  "enabled": true
}
