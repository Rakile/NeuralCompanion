{
  "id": "nc.pockettts",
  "name": "PocketTTS",
  "version": "0.1.0",
  "entry_point": "main.py",
  "description": "Built-in PocketTTS backend exposed as an addon.",
  "category": "global",
  "permissions": [
    "services.register",
    "ui.tabs"
  ],
  "services": [
    {
      "id": "tts_backend_service",
      "backend_id": "pockettts"
    }
  ],
  "ui": [
    {
      "id": "pockettts_tab",
      "title": "PocketTTS",
      "area": "tts_runtime",
      "ui_path": "ui/pockettts.ui",
      "placeholder": "tts_pockettts_tab",
      "order": 200,
      "tooltip": "PocketTTS interpreter settings.",
      "metadata": {
        "backend_id": "pockettts"
      }
    }
  ],
  "enabled": true
}
