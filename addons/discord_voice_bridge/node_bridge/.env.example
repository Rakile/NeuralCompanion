DISCORD_TOKEN=
DISCORD_VOICE_CHANNEL_ID=

# Optional. If omitted, the bridge derives guild ID from the voice channel.
DISCORD_GUILD_ID=

# Optional. If set, only this Discord user is captured.
DISCORD_ALLOWED_USER_ID=

# Set to true to play a short generated tone when the bot joins.
DISCORD_PLAY_TEST_TONE=false

# mock = capture Discord speech and play a generated fake NC reply.
# Later this can become websocket/http when NC exposes the real addon endpoint.
NC_BRIDGE_MODE=mock

# Speech turn ends after this much silence.
DISCORD_SILENCE_MS=900

# Safety cap for one captured voice turn.
DISCORD_MAX_TURN_SECONDS=30

# Ignore tiny captures before sending them to NC/mock NC.
DISCORD_MIN_TURN_SECONDS=0.6

# Mock reply delay makes the test feel closer to a real STT/LLM/TTS round-trip.
MOCK_REPLY_DELAY_MS=450

